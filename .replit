modules = ["nodejs-20", "web", "bash"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 45000

[[ports]]
localPort = 8080
externalPort = 80

[[ports]]
localPort = 21486
externalPort = 3000

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
